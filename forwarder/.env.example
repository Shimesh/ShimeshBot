# ── Telegram API (from https://my.telegram.org → API development tools) ────────
# These are tied to your personal Telegram account, NOT the bot token.
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890

# ── Telegram Session (generated by running: node auth.js) ────────────────────
# ⚠️  Keep this secret — it grants read access to your Telegram account.
TELEGRAM_STRING_SESSION=1BVtsOKABu...

# ── Channel IDs to monitor (run: node discover.js to find them) ──────────────
# Comma-separated negative channel IDs.
# Leave empty to monitor ALL channels (useful during first-run setup).
TELEGRAM_CHANNEL_IDS=-1001234567890,-1009876543210,-1005555555555

# ── WhatsApp Group ID ────────────────────────────────────────────────────────
# Format: <number>@g.us  (e.g. 972501234567-1620000000@g.us)
# Find it: start the bot without this set → scan QR → group list prints to logs.
WHATSAPP_GROUP_ID=972501234567-1620000000@g.us

# ── Server port (Railway sets this automatically) ────────────────────────────
PORT=3000
